FROM node:22.21.0-bookworm-slim

WORKDIR /usr/src/app

# Dépendances système (bcrypt / prisma)
RUN apt-get update && apt-get install -y \
    build-essential \
    python3 \
    && rm -rf /var/lib/apt/lists/*

# Copier uniquement les fichiers nécessaires pour installer
COPY package*.json ./

# Installer proprement avec npm ci
RUN npm ci

# Copier le reste du projet
COPY . .

# Build NestJS
RUN npm run build

EXPOSE 4005

CMD ["node", "dist/main.js"]