// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/dbLumilaya/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum ShippingType {
  REL
  DOM
  OFF
}

model Order {
  id                 Int      @id @default(autoincrement())
  stripeSessionId    String   @unique

  // 👤 Client
  firstName          String
  lastName           String
  email              String
  phone              String

  // 🚚 Livraison
  shippingAddress    String
  shippingCity       String
  shippingPostalCode String
  shippingCountry    String   @db.Char(2)
  shippingType       ShippingType
  shippingPrice      Decimal  @db.Decimal(10, 2)

  // 🧾 Facturation
  billingAddress     String
  billingCity        String
  billingPostalCode  String
  billingCountry     String   @db.Char(2)

  // ✅ Legal
  acceptCGV          Boolean

  // 💰 Total
  total              Decimal  @db.Decimal(10, 2)

  // 🛒 Items
  items              OrderItem[]

  createdAt          DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}

model OrderItem {
  id        Int     @id @default(autoincrement())

  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   Int

  productId Int
  variantId Int

  name      String
  price     Decimal @db.Decimal(10, 2)
  quantity  Int

  @@index([orderId])
}

model Product {
  id          Int       @id @default(autoincrement())

  description String[]
  images      String[]

  meta        ProductMeta @relation(fields: [metaId], references: [id])
  metaId      Int         @unique

  variants    Variant[]

  tags        Tag[]

  wellness    Json?

  reviews     Review[]

  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model ProductMeta {
  id         Int      @id @default(autoincrement())

  collection String
  name       String
  slug       String   @unique
  intro      String

  theme      Json

  stock      Boolean
  promo      Int?
  like       Int?

  createdAt  DateTime @default(now())

  product    Product?
}

model Variant {
  id        Int     @id @default(autoincrement())

  name      String
  duration  Int
  weight    Int
  price     Decimal @db.Decimal(10, 2)

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId Int

  @@index([productId])
}

model Tag {
  id       Int      @id @default(autoincrement())
  name     String   @unique

  products Product[]
}

model ShippingPrice {
  id            Int           @id @default(autoincrement())

  name          String
  zone          String        // "FR", "EU", etc.
  shippingType  ShippingType

  price         Decimal       @db.Decimal(10, 2)

  active        Boolean       @default(true)

  createdAt     DateTime      @default(now())

  @@index([zone, shippingType])
}

model Review {
  id        Int      @id @default(autoincrement())

  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  note      Float
  name      String
  comment   String

  createdAt DateTime @default(now())

  @@index([productId])
}